    "healthSettings.privacyMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Gesundheitsdaten bleiben auf deinem Gerät. Looopr lädt niemals Gesundheitsinformationen auf einen Server hoch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your health data stays on your device. Looopr never uploads health information to any server."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos de salud permanecen en tu dispositivo. Looopr nunca carga información de salud a ningún servidor."
