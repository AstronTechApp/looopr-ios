{
  "sourceLanguage" : "en",
  "strings" : {
    "·" : {
      "comment" : "A period used to separate different pieces of information in a list.",
      "isCommentAutoGenerated" : true
    },
    "(%@)" : {
      "comment" : "A text label showing the number of reviews for an experience. The argument is the count of reviews for the experience.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "A label displaying the user's current walking streak.",
      "isCommentAutoGenerated" : true
    },
    "%@ · %@" : {
      "comment" : "A subheadline displaying the name of the route and the date it was completed.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ (%@)" : {
      "comment" : "The version and build number of the app, displayed in a small font below the app name.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ (%2$@)"
          }
        }
      }
    },
    "%@ %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@%% complete" : {
      "comment" : "A label showing the percentage of the walk that has been completed.",
      "isCommentAutoGenerated" : true
    },
    "~%@ min" : {
      "comment" : "A label showing the estimated travel time to a point of interest. The argument is the estimated travel time in minutes.",
      "isCommentAutoGenerated" : true
    },
    "APPROACHING" : {
      "comment" : "The title of the banner that appears when a user is approaching a Point of Interest (POI).",
      "isCommentAutoGenerated" : true
    },
