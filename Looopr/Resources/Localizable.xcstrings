      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Aktion kann nicht rückgängig gemacht werden. Alle deine Daten, Erinnerungen und dein Wanderverlauf werden dauerhaft gelöscht."
