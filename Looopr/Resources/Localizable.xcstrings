    "auth.privacyAgreement" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die Anmeldung stimmst du unserer [Datenschutzrichtlinie](https://looopr.app/privacy) zu. Wir erfassen deinen Namen, deine E-Mail, gespeicherte Routen und deinen Wanderverlauf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By signing in, you agree to our [Privacy Policy](https://looopr.app/privacy). We collect your name, email, saved routes, and walk history to provide the service."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al iniciar sesión, aceptas nuestra [Política de privacidad](https://looopr.app/privacy). Recopilamos tu nombre, correo, rutas guardadas e historial de caminatas."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al iniciar sesión, aceptas nuestra [Política de privacidad](https://looopr.app/privacy). Recopilamos tu nombre, correo, rutas guardadas e historial de caminatas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En vous connectant, vous acceptez notre [Politique de confidentialité](https://looopr.app/privacy). Nous collectons votre nom, e-mail, itinéraires sauvegardés et historique de marche."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accedendo, accetti la nostra [Informativa sulla privacy](https://looopr.app/privacy). Raccogliamo nome, email, percorsi salvati e cronologia delle passeggiate."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Door in te loggen ga je akkoord met ons [Privacybeleid](https://looopr.app/privacy). We verzamelen je naam, e-mail, opgeslagen routes en wandelgeschiedenis om de service te bieden."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao fazer login, você concorda com nossa [Política de Privacidade](https://looopr.app/privacy). Coletamos seu nome, e-mail, rotas salvas e histórico de caminhadas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao iniciar sessão, aceita a nossa [Política de Privacidade](https://looopr.app/privacy). Recolhemos o seu nome, e-mail, rotas guardadas e histórico de caminhadas."
          }
        }
      }
    },
